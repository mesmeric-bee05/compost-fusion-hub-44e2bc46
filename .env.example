# Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# M-Pesa Daraja API
MPESA_ENVIRONMENT="sandbox" # or "production"
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_SHORT_CODE="your-short-code"
MPESA_PASSKEY="your-passkey"
MPESA_CALLBACK_URL="https://yourdomain.com/api/payment/mpesa/callback"

# Africa's Talking (USSD, SMS, Payments)
AFRICASTALKING_USERNAME="your-africastalking-username"
AFRICASTALKING_API_KEY="your-africastalking-api-key"
AFRICASTALKING_SHORT_CODE="your-africastalking-short-code" # e.g., 20880
AFRICASTALKING_USSD_ENDPOINT="https://yourapp.com/api/ussd" # Your USSD callback URL

# WhatsApp Business API
WHATSAPP_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_BUSINESS_ID="your-whatsapp-business-id"
WHATSAPP_VERIFY_TOKEN="your-verify-token"
WHATSAPP_API_VERSION="v17.0"
WHATSAPP_WEBHOOK_URL="https://yourdomain.com/api/whatsapp/webhook"

# Optional: Redis for production rate limiting and session storage
# REDIS_URL="redis://default:[PASSWORD]@[ REDIS_ENDPOINT ]:[PORT]"

# Optional: Cloudinary for file storage
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"