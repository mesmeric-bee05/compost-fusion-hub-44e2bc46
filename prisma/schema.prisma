/// Prisma schema for Captain Compost
/// Generated based on Supabase schema from migrations

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// Enums
enum AppRole {
  INDIVIDUAL
  FARMER
  INSTITUTION
  RECYCLER
  DRIVER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum WasteType {
  ORGANIC
  RECYCLABLE
  AGRICULTURAL
  MIXED
}

enum CollectionStatus {
  REQUESTED
  SCHEDULED
  COLLECTED
  CANCELLED
}

enum ScheduleFrequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ContentType {
  ARTICLE
  VIDEO
  GUIDE
  COURSE
}

// Models
model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  fullName      String   @default("")
  phone         String?
  avatarUrl     String?
  location      String?
  bio           String?
  language      String   @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  userRoles     UserRole[] @relation("userRoles")
  rewards       Rewards? @relation("rewards")
  impactMetrics ImpactMetric[] @relation("impactMetrics")
  forumPosts    ForumPost[] @relation("forumPosts")
  productReviews ProductReview[] @relation("productReviews")
  wishlist      Wishlist[] @relation("wishlist")
  orders        Order[] @relation("orders")
  collectionRequests CollectionRequest[] @relation("collectionRequests")
  assignedCollections CollectionRequest[] @relation("assignedCollections")
  authoredContent Content[] @relation("content")
  forumComments ForumComment[] @relation("forumComments")

  @@index([userId])
}

model UserRole {
  id      String @id @default(cuid())
  userId  String
  role    AppRole

  // Relations
  user Profile @relation("userRoles", fields: [userId], references: [id])

  @@unique([userId, role])
  @@index([userId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  shortDescription String?
  category      String   @default("composters")
  price         Float    @default(0)
  currency      String   @default("KES")
  imageUrl      String?
  gallery       Json     // Storing as JSON array instead of String[]
  specifications Json
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  bulkDiscountPercent Float @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  orderItems    OrderItem[] @relation("orderItems")
  productReviews ProductReview[] @relation("productReviews")
  wishlist      Wishlist[] @relation("wishlist")

  @@index([slug])
  @@index([isActive])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Float   @default(0)
  deliveryAddress String?
  deliveryPhone   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user       Profile @relation("orders", fields: [userId], references: [userId])
  orderItems OrderItem[] @relation("orderItems")
  payments   Payment[] @relation("payments")

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int      @default(1)
  unitPrice Float    @default(0)
  totalPrice Float  @default(0)

  // Relations
  order    Order @relation("orderItems", fields: [orderId], references: [id])
  product  Product @relation("orderItems", fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String
  mpesaRequestId  String?
  mpesaReceiptNo  String?
  amount          Float
  status          String   // PENDING, PAID, FAILED
  confirmedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  order Order @relation("payments", fields: [orderId], references: [id])

  @@index([orderId])
  @@index([mpesaRequestId])
  @@index([status])
}

model CollectionRequest {
  id              String   @id @default(cuid())
  userId          String
  driverId        String?
  wasteType       WasteType @default(ORGANIC)
  estimatedVolumeKg Float   @default(0)
  address         String
  pickupDate      DateTime
  pickupTime      String?
  frequency       ScheduleFrequency @default(ONE_TIME)
  status          CollectionStatus @default(REQUESTED)
  verificationPhotoUrl String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user    Profile @relation("collectionRequests", fields: [userId], references: [id])
  driver  Profile? @relation("assignedCollections", fields: [driverId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([status])
}

model Content {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String?
  category    String   @default("composting")
  contentType ContentType @default(ARTICLE)
  imageUrl    String?
  videoUrl    String?
  language    String   @default("en")
  isPublished Boolean  @default(false)
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  author Profile? @relation("content", fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished])
}

model ImpactMetric {
  id           String   @id @default(cuid())
  userId       String
  wasteDivertedKg Float   @default(0)
  co2SavedKg   Float   @default(0)
  compostProducedKg Float @default(0)
  treesEquivalent Float  @default(0)
  recordedAt   DateTime @default(now())

  // Relations
  user Profile @relation("impactMetrics", fields: [userId], references: [id])

  @@index([userId])
  @@index([recordedAt])
}

model Rewards {
  id      String   @id @default(cuid())
  userId  String   @unique
  points  Int      @default(0)
  level   String   @default("beginner")
  badges  Json     // Storing as JSON array instead of String[]
  updatedAt DateTime @updatedAt

  // Relations
  user Profile @relation("rewards", fields: [userId], references: [userId])

  @@index([userId])
}

model ForumPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  category  String   @default("general")
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user Profile @relation("forumPosts", fields: [userId], references: [id])
  comments ForumComment[] @relation("forumComments")

  @@index([userId])
  @@index([isPinned])
  @@index([createdAt])
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String
  isHelpful Boolean  @default(false)
  parentId  String? // for nested comments (max 2 levels)
  createdAt DateTime @default(now())

  // Relations
  post    ForumPost @relation("forumComments", fields: [postId], references: [id])
  user    Profile   @relation("forumComments", fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  // Relations
  product Product @relation("productReviews", fields: [productId], references: [id])
  user    Profile @relation("productReviews", fields: [userId], references: [userId])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])

  // Note: Rating validation (1-5) should be handled in application layer
  // or via database triggers/check constraints
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  // Relations
  user    Profile @relation("wishlist", fields: [userId], references: [id])
  product Product @relation("wishlist", fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}